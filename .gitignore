test-firestore-write.py
test-edicao-*.py

# ── Logs de execução local ─────────────────────────────────────────────────────
docs/logs/

# ── Backups automáticos do index.html ─────────────────────────────────────────
index.backup-*.html

# ── Configuração de editores locais ───────────────────────────────────────────
.obsidian/
.claude/

# ── Arquivos de sistema Windows ───────────────────────────────────────────────
Thumbs.db
desktop.ini

